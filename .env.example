# Copy this file to .env before running the app.
# These defaults match docker-compose.yml.

POSTGRES_USER=langchain
POSTGRES_PASSWORD=langchain
POSTGRES_DB=langchain_rag
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Local PDF directory
DATA_DIR=data

# Chunking settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=3

# Simple fully local embedding backend.
EMBEDDING_MODEL=simple-hashing
EMBEDDING_DIMENSION=384

# Keep this as context_only for a no-API beginner setup.
# Switch to openai if you want API-based answer generation.
LLM_BACKEND=context_only
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
